@echo off
chcp 65001 >nul 2>&1

:: =============================================================================
:: Messenger — iOS клиент (Windows)
:: =============================================================================
:: iOS-приложение можно собрать ТОЛЬКО на macOS с установленным Xcode.
:: Этот файл информирует пользователя об альтернативных вариантах.
:: =============================================================================

title Messenger iOS — Требуется macOS

echo.
echo  ===================================================================
echo    Messenger — iOS Client
echo  ===================================================================
echo.
echo  [!] iOS-приложение можно собрать и установить только на macOS.
echo.
echo      Apple требует Xcode, который доступен исключительно для macOS.
echo      Собрать или запустить iOS-приложение на Windows невозможно.
echo.
echo  ── Как установить iOS-клиент ────────────────────────────────────────
echo.
echo    1. Перейдите на компьютер Mac с установленным Xcode.
echo    2. Скопируйте репозиторий Messenger на Mac.
echo    3. Запустите скрипт:  install-client-ios.sh
echo.
echo  ── Альтернативы для Windows ────────────────────────────────────────
echo.
echo    PWA (браузерное приложение):
echo      install-client-pwa.bat
echo      После сборки откройте в Safari на iPhone и нажмите
echo      "Добавить на главный экран" для установки как приложения.
echo.
echo    Android:
echo      install-client-android.bat
echo      Установите APK на Android-устройство.
echo.
echo    Desktop (Windows):
echo      install-client-windows.bat
echo      Запустите Messenger как нативное приложение Windows.
echo.
echo  ===================================================================
echo.
pause
