{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist-types",
    "noEmit": false
  },
  "include": [
    "./index.ts",
    "./auth/**/*.ts",
    "./websocket/**/*.ts",
    "./messages/**/*.ts",
    "./sync/**/*.ts",
    "./storage/**/*.ts",
    "./crypto/**/*.ts",
    "../../client/src/api/client.ts",
    "../../client/src/config/serverConfig.ts",
    "../../client/src/crypto/x3dh.ts",
    "../../client/src/crypto/ratchet.ts",
    "../../client/src/crypto/senderkey.ts",
    "../../client/src/crypto/session.ts",
    "../../client/src/crypto/keystore.ts",
    "../../client/src/types/index.ts"
  ],
  "exclude": [
    "./**/*.test.ts"
  ]
}
